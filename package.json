{
  "name": "@excel.js/exceljs",
  "version": "0.7.0",
  "description": "Excel Workbook Manager - Read and Write xlsx and csv Files.",
  "license": "MIT",
  "imports": {
    "#utils/*": "./lib/utils/*.js",
    "#doc/*": "./lib/doc/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excel-js/exceljs.git"
  },
  "engines": {
    "node": ">=20"
  },
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "test": "npm run build && npm run test:unit && npm run test:integration && npm run test:end-to-end",
    "test:bun": "bun test tests",
    "test:unit": "mocha --require spec/config/setup spec/unit --recursive",
    "test:integration": "mocha --require spec/config/setup spec/integration --recursive",
    "test:end-to-end": "mocha --require spec/config/setup spec/end-to-end --recursive",
    "benchmark": "node --expose-gc benchmark",
    "benchmark:debug": "node --expose-gc --inspect-brk --trace-deopt benchmark",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "xlsx",
    "json",
    "csv",
    "excel",
    "font",
    "border",
    "fill",
    "number",
    "format",
    "number format",
    "alignment",
    "office",
    "spreadsheet",
    "workbook",
    "defined names",
    "data validations",
    "rich text",
    "in-cell format",
    "outlineLevel",
    "views",
    "frozen",
    "split",
    "pageSetup"
  ],
  "dependencies": {
    "@excel.js/jszip": "0.0.2",
    "@excel.js/unzipper": "0.0.2",
    "archiver": "^5.0.0",
    "dayjs": "^1.8.34",
    "fast-csv": "^4.3.1",
    "saxes": "^5.0.1",
    "tmp": "^0.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/chai": "^4.2.12",
    "@types/mocha": "^8.0.3",
    "@types/node": "^20",
    "chai": "^4.2.0",
    "chai-datetime": "^1.7.0",
    "chai-xml": "^0.3.2",
    "dirty-chai": "^2.0.1",
    "express": "^4.16.4",
    "got": "^9.0.0",
    "mocha": "^8.0.0",
    "sax": "^1.2.4",
    "tsdown": "^0.21.7",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./modelcontainer": "./dist/modelcontainer.mjs",
    "./workbook": "./dist/workbook.mjs",
    "./package.json": "./package.json"
  }
}
